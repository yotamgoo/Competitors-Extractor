PORT=8080

# Optional shared Airtable defaults used by all extractors unless an extractor-specific
# override is set below.
AIRTABLE_PAT=pat_your_token
AIRTABLE_BASE_ID=app_your_base_id
AIRTABLE_COMPETITORS_TABLE=Competitors
AIRTABLE_ADS_TABLE=Ads
AIRTABLE_COMPETITORS_ACTIVE_FIELD=Active
AIRTABLE_COMPETITORS_NAME_FIELD=Name
CHUNK_MAX_MS=300000
CHUNK_MAX_CHECKPOINTS=10
CHECKPOINT_RETRY_LIMIT=3
CHECKPOINT_STALE_MINUTES=10

# Foreplay
FOREPLAY_EMAIL=your-email@example.com
FOREPLAY_PASSWORD=your-password
FOREPLAY_AIRTABLE_PAT=
FOREPLAY_AIRTABLE_BASE_ID=
FOREPLAY_AIRTABLE_COMPETITORS_TABLE=Competitors
FOREPLAY_AIRTABLE_ADS_TABLE=Ads
FOREPLAY_AIRTABLE_CHECKPOINTS_TABLE=Checkpoints
FOREPLAY_AIRTABLE_COMPETITORS_ACTIVE_FIELD=Active
FOREPLAY_AIRTABLE_COMPETITORS_NAME_FIELD=Name
FOREPLAY_AIRTABLE_COMPETITORS_FOREPLAY_FIELD=Page Id
FOREPLAY_CHUNK_MAX_MS=300000
FOREPLAY_CHUNK_MAX_CHECKPOINTS=10
FOREPLAY_CHECKPOINT_RETRY_LIMIT=3
FOREPLAY_CHECKPOINT_STALE_MINUTES=10

# AdPlexity
ADPLEXITY_EMAIL=your-email@example.com
ADPLEXITY_PASSWORD=your-password
ADPLEXITY_AIRTABLE_PAT=
ADPLEXITY_AIRTABLE_BASE_ID=
ADPLEXITY_AIRTABLE_COMPETITORS_TABLE=Competitors
ADPLEXITY_AIRTABLE_ADS_TABLE=Ads
ADPLEXITY_AIRTABLE_CHECKPOINTS_TABLE=Adplexity Checkpoints
ADPLEXITY_AIRTABLE_COMPETITORS_ACTIVE_FIELD=Active
ADPLEXITY_AIRTABLE_COMPETITORS_NAME_FIELD=Name
ADPLEXITY_AIRTABLE_COMPETITORS_ADPLEXITY_FIELD=AdPlexity Report ID
ADPLEXITY_CHUNK_MAX_MS=300000
ADPLEXITY_CHUNK_MAX_CHECKPOINTS=10
ADPLEXITY_CHECKPOINT_RETRY_LIMIT=3
ADPLEXITY_CHECKPOINT_STALE_MINUTES=10

# Meta
META_AIRTABLE_PAT=
META_AIRTABLE_BASE_ID=
META_AIRTABLE_COMPETITORS_TABLE=Competitors
META_AIRTABLE_ADS_TABLE=Ads
META_AIRTABLE_CHECKPOINTS_TABLE=Meta Checkpoints
META_AIRTABLE_COMPETITORS_ACTIVE_FIELD=Active
META_AIRTABLE_COMPETITORS_NAME_FIELD=Name
META_AIRTABLE_COMPETITORS_META_PAGE_FIELD=Meta Page ID
META_CHUNK_MAX_MS=300000
META_CHUNK_MAX_CHECKPOINTS=10
META_CHECKPOINT_RETRY_LIMIT=3
META_CHECKPOINT_STALE_MINUTES=10
META_MIN_DAYS=30
META_MEDIA=both
META_MAX_ADS_PER_PAGE=100
META_SLICE_MAX_ADS=30
META_GRAPHQL_API_URL=https://www.facebook.com/api/graphql/
META_GRAPHQL_DOC_ID=25987067537594875
META_GRAPHQL_FRIENDLY_NAME=AdLibrarySearchPaginationQuery
META_X_ASBD_ID=359341
META_ACCEPT_LANGUAGE=en-GB,en-US;q=0.9,en;q=0.8,he;q=0.7
META_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36
META_REQUEST_TIMEOUT_MS=90000

# Paste one full application/x-www-form-urlencoded body from a real
# AdLibrarySearchPaginationQuery request in your Meta HAR.
META_GRAPHQL_FORM_TEMPLATE=

# Optional Meta session extras if body-only requests are not enough.
META_COOKIE=
META_FB_DTSG=
META_X_FB_LSD=
