# App
PORT=8080

# Airtable
AIRTABLE_PAT=
AIRTABLE_BASE_ID=

# Source Ads table
TRANSCRIPTION_AIRTABLE_ADS_TABLE=Ads
TRANSCRIPTION_AIRTABLE_ADS_VIEW=
TRANSCRIPTION_AIRTABLE_ADS_AD_ID_FIELD=Ad Id
TRANSCRIPTION_AIRTABLE_ADS_ATTACHMENT_FIELD=Ad File
TRANSCRIPTION_AIRTABLE_ADS_TRANSCRIPT_FIELD=Video Transcript

# Queue table
TRANSCRIPTION_AIRTABLE_QUEUE_TABLE=Transcriptions
TRANSCRIPTION_AIRTABLE_QUEUE_VIEW=
TRANSCRIPTION_AIRTABLE_QUEUE_AD_ID_FIELD=
TRANSCRIPTION_AIRTABLE_QUEUE_ADS_RECORD_ID_FIELD=
TRANSCRIPTION_AIRTABLE_QUEUE_AD_LINK_FIELD=Ad
TRANSCRIPTION_AIRTABLE_QUEUE_TRANSCRIPT_FIELD=Video Transcript
TRANSCRIPTION_AIRTABLE_QUEUE_STATUS_FIELD=Transcript Status
TRANSCRIPTION_AIRTABLE_QUEUE_ERROR_FIELD=Transcript Error
TRANSCRIPTION_AIRTABLE_QUEUE_UPDATED_AT_FIELD=Transcript Updated At
TRANSCRIPTION_AIRTABLE_QUEUE_ATTEMPT_COUNT_FIELD=Transcript Attempt Count
TRANSCRIPTION_AIRTABLE_QUEUE_HEARTBEAT_FIELD=Transcript Heartbeat At
TRANSCRIPTION_AIRTABLE_QUEUE_LANGUAGE_FIELD=Transcript Language
TRANSCRIPTION_AIRTABLE_QUEUE_SEEDED_AT_FIELD=
TRANSCRIPTION_AIRTABLE_QUEUE_COMPLETED_AT_FIELD=

# Runtime
TRANSCRIPTION_CHUNK_MAX_MS=180000
TRANSCRIPTION_CHUNK_MAX_RECORDS=10
TRANSCRIPTION_RETRY_LIMIT=3
TRANSCRIPTION_STALE_MINUTES=15
TRANSCRIPTION_MAX_INLINE_BYTES=15000000

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
TRANSCRIPTION_LANGUAGE=
TRANSCRIPTION_PROMPT=Transcribe all spoken words from this video verbatim from start to finish. Do not summarize, shorten, paraphrase, or describe the video. Return only the complete transcript text in reading order. If there is no speech, return exactly NO_SPEECH.
IMAGE_DESCRIPTION_PROMPT=Describe this ad image in one short paragraph for marketing classification. Mention the core visual, product or offer, any visible text or CTA, audience cues, and the likely creative angle. Keep it concise, plain, and useful for later vertical filtering. Return only the paragraph.
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=0.1
GEMINI_REQUEST_TIMEOUT_MS=120000
